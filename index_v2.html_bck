<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sistema de Indicadores AIFA</title>
  <meta name="color-scheme" content="light dark" />

  <!-- Tailwind (válido para desarrollo; en producción conviene compilar) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Lucide icons y Chart.js (globales) -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- Supabase v2 (expone window.supabase) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <!-- Tipografía opcional -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root { color-scheme: light; }
    html, body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji"; }
    /* Animación simple para toasts */
    .toast { opacity: 0; transform: translateY(-4px); transition: opacity .25s ease, transform .25s ease; }
    .toast.show { opacity: 1; transform: translateY(0); }
  </style>
</head>

<body class="bg-gray-50 min-h-screen">

  <!-- Barra superior -->
  <header class="bg-white border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="./AIFA_Logo.png" alt="AIFA" class="h-10 w-10 object-contain" onerror="this.style.display='none'">
        <div>
          <h1 class="text-lg sm:text-xl font-bold text-gray-900">Sistema de Indicadores AIFA</h1>
          <p class="text-xs text-gray-500">Aeropuerto Internacional Felipe Ángeles</p>
        </div>
      </div>

      <!-- Navegación principal (IDs que usa router.js) -->
      <nav class="hidden md:flex items-center gap-2">
        <button id="nav-home" class="nav-button inline-flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 bg-white hover:bg-blue-50 hover:text-aifa-blue">
          <i data-lucide="home" class="w-4 h-4"></i><span>Inicio</span>
        </button>
        <button id="nav-visualizacion" class="nav-button inline-flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 bg-white hover:bg-blue-50 hover:text-aifa-blue">
          <i data-lucide="line-chart" class="w-4 h-4"></i><span>Visualización</span>
        </button>
        <button id="nav-captura" class="nav-button inline-flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 bg-white hover:bg-blue-50 hover:text-aifa-blue">
          <i data-lucide="file-plus-2" class="w-4 h-4"></i><span>Captura</span>
        </button>
        <button id="nav-admin" class="nav-button inline-flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 bg-white hover:bg-blue-50 hover:text-aifa-blue">
          <i data-lucide="settings" class="w-4 h-4"></i><span>Administración</span>
        </button>
      </nav>

      <!-- Menú usuario -->
      <div class="flex items-center gap-2">
        <button id="user-menu" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-gray-600 bg-white hover:bg-gray-100">
          <i data-lucide="user" class="w-4 h-4"></i><span class="hidden sm:inline">Cuenta</span>
        </button>
      </div>
    </div>
  </header>

  <!-- Breadcrumb -->
  <div class="bg-gray-100 border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 text-sm text-gray-600" id="breadcrumb">
      <span class="inline-flex items-center gap-2"><i data-lucide="map-pin" class="w-4 h-4"></i> Inicio</span>
    </div>
  </div>

  <!-- Contenedor principal para vistas -->
  <main id="app-container" class="max-w-7xl mx-auto p-4"></main>

  <!-- Contenedor de notificaciones -->
  <div id="toast-container" class="fixed top-4 right-4 z-50"></div>

  <!-- Loading overlay -->
  <div id="loading-container" class="fixed inset-0 hidden z-40">
    <div class="w-full h-full flex items-center justify-center bg-black/30 backdrop-blur-sm">
      <div class="bg-white px-4 py-3 rounded-lg shadow flex items-center gap-3">
        <i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i>
        <span>Cargando…</span>
      </div>
    </div>
  </div>

  <!-- Modal genérico -->
  <div id="modal-overlay" class="fixed inset-0 hidden z-50 bg-black/40">
    <div class="mx-auto mt-24 max-w-lg bg-white rounded-lg shadow p-4">
      <h3 id="modal-title" class="text-lg font-semibold mb-2">Modal</h3>
      <div id="modal-content" class="mb-4"></div>
      <div id="modal-actions" class="flex justify-end gap-2"></div>
    </div>
  </div>

  <!-- Bootstrap de la app: un solo módulo, rutas relativas -->
  <script type="module">
    // Arranque de la app (solo un módulo). NO incluyas config.js ni vistas aquí.
    import * as router from './js/lib/router.js';
    import * as ui from './js/lib/ui.js';

    // Exponer helpers globales que usan tus vistas/HTML (toasts, navegación, etc.)
    window.ui = ui;
    window.router = {
      navigateTo: router.navigateTo,
      goBack: router.goBack,
      reloadCurrentRoute: router.reloadCurrentRoute,
      parseCurrentRoute: router.parseCurrentRoute
    };

    // Clicks del header
    function bindNav() {
      document.getElementById('nav-home')?.addEventListener('click', () => router.navigateTo('/'));
      document.getElementById('nav-visualizacion')?.addEventListener('click', () => router.navigateTo('/visualizacion'));
      document.getElementById('nav-captura')?.addEventListener('click', () => router.navigateTo('/captura'));
      document.getElementById('nav-admin')?.addEventListener('click', () => router.navigateTo('/admin'));
    }

    // Init
    window.addEventListener('DOMContentLoaded', () => {
      bindNav();

      // Si entras sin hash, manda a home; los guards redirigen a /login si no hay sesión
      if (!location.hash) {
        router.navigateTo('/', {}, true);
      } else {
        router.reloadCurrentRoute?.();
      }

      // Pintar iconos Lucide
      if (window.lucide) window.lucide.createIcons();
    });

    // Repintar iconos cuando cambie la vista por el hash
    window.addEventListener('hashchange', () => {
      if (window.lucide) window.lucide.createIcons();
    });
  </script>
</body>
</html>
